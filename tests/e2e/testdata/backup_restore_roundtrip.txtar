# backup + restore roundtrip
# Creates a backup, then verifies restore command works with --dry-run.

# Run backup with quick preset.
exec bak backup --preset quick
stdout 'Backup created:'

# The backup directory must exist.
exists .bak/backups

# Run restore with --help to verify the command is wired correctly.
exec bak restore --help
stdout 'dry-run'

# Restore with --dry-run using a non-existent ID should fail properly.
! exec bak restore --dry-run nonexistent-id-12345
stderr 'not found'
