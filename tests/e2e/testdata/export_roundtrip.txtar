# export roundtrip
# Pre-creates a backup fixture, exports it, and verifies the tar.gz output.
# Also tests error paths: invalid ID and non-existent backup.

# Happy path: export a valid backup with default output name.
exec bak export 20250609-120000
stdout 'Exported backup'
exists bak-export.tar.gz

# Export with custom output path.
exec bak export 20250609-120000 --output out.tar.gz
stdout 'Exported backup'
exists out.tar.gz

# Custom output using -o shorthand.
exec bak export 20250609-120000 -o custom.tar.gz
stdout 'Exported backup'
exists custom.tar.gz

# Error: invalid backup ID (wrong format).
! exec bak export bad-id
stderr 'invalid backup ID'

# Error: invalid backup ID (wrong length).
! exec bak export 20250101
stderr 'invalid backup ID'

# Error: non-existent backup (valid format but not on disk).
! exec bak export 20250101-000000
stderr 'not found'

# Verify export --help shows usage.
exec bak export --help
stdout 'export <backup-id>'

# Pre-created backup fixture with manifest and test file.
