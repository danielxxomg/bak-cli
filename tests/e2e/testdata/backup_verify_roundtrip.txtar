# backup + verify roundtrip
# Creates a backup, verifies its integrity, then tampers with a file
# and re-verifies to confirm corruption is detected. Also tests
# invalid-ID error handling.

# Run backup with quick preset.
exec bak backup --preset quick
stdout 'Backup created:'

# The backup directory must exist.
exists .bak/backups

# Capture the backup ID.
exec sh -c 'ls .bak/backups/ | head -1 > $WORK/bak_id.txt'

# Run verify — should pass with checkmark and verified message.
exec sh -c 'ID=$(cat $WORK/bak_id.txt) && bak verify $ID'
stdout '✓ backup'
stdout 'verified'

# Tamper with a file inside the backup directory (simulate corruption).
exec sh -c 'ID=$(cat $WORK/bak_id.txt) && echo "corrupted-content" > .bak/backups/$ID/opencode/opencode.json'

# Re-verify — should fail with checksum mismatch.
! exec sh -c 'ID=$(cat $WORK/bak_id.txt) && bak verify $ID'
stderr 'hash mismatch'

# Verify with invalid ID should fail gracefully.
! exec bak verify 20000101-000000
stderr 'not found'
